{
  "build": {
    "env": {
      "ESLINT_NO_DEV_ERRORS": "true",
      "TSC_COMPILE_ON_ERROR": "true"
    }
  },
  "redirects": [
    {
      "source": "/verifyotp",
      "destination": "/verify-otp",
      "permanent": true
    }
  ],
  "routes": [
    {
      "src": "/[^.]+",
      "dest": "/",
      "status": 200
    }
  ]
}
